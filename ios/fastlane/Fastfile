default_platform(:ios)

platform :ios do
  def flutter_version_data
    pubspec_path = File.expand_path('../../pubspec.yaml', __dir__)
    version_line = File.read(pubspec_path).lines.find { |line| line.start_with?('version:') }
    UI.user_error!('No se encontró version en pubspec.yaml') if version_line.nil?

    version_value = version_line.split(':', 2).last.strip
    parts = version_value.split('+')
    build_name = parts[0]
    build_number = parts[1]

    UI.user_error!("Versión inválida en pubspec.yaml: #{version_value}") if build_name.to_s.empty? || build_number.to_s.empty?

    { build_name: build_name, build_number: build_number }
  end

  desc "Generate certificates and profiles"
  lane :certificates do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_CONTENT'],
      in_house: false
    )
    
    match(
      type: "appstore",
      readonly: false,
      force_for_new_devices: true,
      api_key: api_key,
      git_url: ENV['MATCH_GIT_URL'],
      git_basic_authorization: ENV['MATCH_GIT_BASIC_AUTHORIZATION']
    )
  end

  desc "Build and sign iOS app for TestFlight"
  lane :build_testflight do
    setup_ci if ENV['CI']

    version_data = flutter_version_data
    run_number = ENV['GITHUB_RUN_NUMBER'].to_i
    desired_build_number = [version_data[:build_number].to_i, run_number].max.to_s

    increment_version_number(
      version_number: version_data[:build_name],
      xcodeproj: 'Runner.xcodeproj'
    )

    increment_build_number(
      build_number: desired_build_number,
      xcodeproj: 'Runner.xcodeproj'
    )
    
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_CONTENT'],
      in_house: false
    )
    
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_url: ENV['MATCH_GIT_URL'],
      git_basic_authorization: ENV['MATCH_GIT_BASIC_AUTHORIZATION']
    )
    
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV['TEAM_ID'],
      bundle_identifier: "com.zentavo.controlgastos",
      profile_name: "match AppStore com.zentavo.controlgastos",
      code_sign_identity: "Apple Distribution"
    )
    
    build_app(
      scheme: "Runner",
      export_method: "app-store",
      export_team_id: ENV['TEAM_ID'],
      export_options: {
        provisioningProfiles: {
          "com.zentavo.controlgastos" => "match AppStore com.zentavo.controlgastos"
        }
      }
    )
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_CONTENT'],
      in_house: false
    )
    
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: false,
      distribute_external: false
    )
  end
end
