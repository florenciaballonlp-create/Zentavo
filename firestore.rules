rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Reglas públicas para MVP sin auth.
    // Endurecidas para validar estructura y limitar payloads inválidos.
    match /shared_events/{code} {
      function isValidCode() {
        return code.matches('^[A-Z0-9]{6}$');
      }

      function hasValidTopLevelShape() {
        return request.resource.data.keys().hasOnly(['code', 'event', 'updatedAt']) &&
          request.resource.data.code is string &&
          request.resource.data.code == code &&
          request.resource.data.event is map;
      }

      function eventPayload() {
        return request.resource.data.event;
      }

      function hasValidEventShape() {
        return eventPayload().keys().hasAll([
            'id',
            'nombre',
            'presupuesto',
            'fechaInicio',
            'participantes',
            'gastos',
            'colorHex',
            'codigoCompartir'
          ]) &&
          eventPayload().keys().hasOnly([
            'id',
            'nombre',
            'descripcion',
            'presupuesto',
            'fechaInicio',
            'fechaFin',
            'participantes',
            'gastos',
            'colorHex',
            'codigoCompartir'
          ]) &&
          eventPayload().id is string &&
          eventPayload().id.size() > 0 &&
          eventPayload().id.size() <= 120 &&
          eventPayload().nombre is string &&
          eventPayload().nombre.size() > 0 &&
          eventPayload().nombre.size() <= 120 &&
          (!('descripcion' in eventPayload()) || eventPayload().descripcion is string) &&
          (!('fechaFin' in eventPayload()) || eventPayload().fechaFin == null || eventPayload().fechaFin is string) &&
          eventPayload().presupuesto is number &&
          eventPayload().presupuesto >= 0 &&
          eventPayload().fechaInicio is string &&
          eventPayload().fechaInicio.size() >= 10 &&
          eventPayload().fechaInicio.size() <= 40 &&
          eventPayload().participantes is list &&
          eventPayload().participantes.size() <= 200 &&
          eventPayload().gastos is list &&
          eventPayload().gastos.size() <= 5000 &&
          eventPayload().colorHex is string &&
          eventPayload().colorHex.size() >= 6 &&
          eventPayload().colorHex.size() <= 8 &&
          eventPayload().codigoCompartir is string &&
          eventPayload().codigoCompartir == code;
      }

      allow read: if isValidCode();

      allow create, update: if isValidCode() &&
        hasValidTopLevelShape() &&
        hasValidEventShape();

      allow delete: if isValidCode();
    }

    match /direct_chats/{chatId} {
      function userIsParticipantInExisting() {
        return signedIn() && request.auth.uid in resource.data.participants;
      }

      function userIsParticipantInNew() {
        return signedIn() && request.auth.uid in request.resource.data.participants;
      }

      allow read: if userIsParticipantInExisting();

      allow create: if userIsParticipantInNew() &&
        request.resource.data.keys().hasAll([
          'participants',
          'participantNames',
          'lastMessageText',
          'lastMessageAt',
          'lastMessageSenderId',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2 &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participantNames is map;

      allow update: if userIsParticipantInExisting();

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if userIsParticipantInExisting();

        allow create: if userIsParticipantInExisting() &&
          request.resource.data.keys().hasAll([
            'senderId',
            'text',
            'type',
            'deletedForAll',
            'createdAt'
          ]) &&
            request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 1500 &&
          request.resource.data.type == 'text';

        allow update, delete: if false;
      }
    }

    match /event_chats/{eventId} {
      function userIsMemberInExisting() {
        return signedIn() && request.auth.uid in resource.data.memberIds;
      }

      function userIsMemberInNew() {
        return signedIn() && request.auth.uid in request.resource.data.memberIds;
      }

      allow read: if userIsMemberInExisting();

      allow create: if userIsMemberInNew() &&
        request.resource.data.keys().hasAll([
          'eventId',
          'eventName',
          'memberIds',
          'lastMessageText',
          'lastMessageAt',
          'lastMessageSenderId',
          'updatedAt'
        ]) &&
        request.resource.data.eventId == eventId &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.memberIds is list;

      allow update: if userIsMemberInExisting();

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if userIsMemberInExisting();

        allow create: if userIsMemberInExisting() &&
          request.resource.data.keys().hasAll([
            'senderId',
            'text',
            'type',
            'deletedForAll',
            'createdAt'
          ]) &&
            request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 1500 &&
          request.resource.data.type == 'text';

        allow update, delete: if false;
      }
    }

    match /event_notes/{eventId} {
      function userIsMemberInExisting() {
        return signedIn() && request.auth.uid in resource.data.memberIds;
      }

      function userIsMemberInNew() {
        return signedIn() && request.auth.uid in request.resource.data.memberIds;
      }

      allow read: if userIsMemberInExisting();

      allow create: if userIsMemberInNew() &&
        request.resource.data.keys().hasAll(['eventId', 'eventName', 'memberIds', 'updatedAt']) &&
        request.resource.data.eventId == eventId &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.memberIds is list;

      allow update: if userIsMemberInExisting();

      allow delete: if false;

      match /posts/{postId} {
        allow read: if userIsMemberInExisting();

        allow create: if userIsMemberInExisting() &&
          request.resource.data.keys().hasAll([
            'authorId',
            'title',
            'body',
            'pinned',
            'createdAt',
            'updatedAt'
          ]) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.title.size() <= 120 &&
          request.resource.data.body is string &&
          request.resource.data.body.size() > 0 &&
          request.resource.data.body.size() <= 4000;

        allow update: if userIsMemberInExisting() &&
          request.auth.uid == resource.data.authorId;

        allow delete: if userIsMemberInExisting() &&
          request.auth.uid == resource.data.authorId;
      }
    }

    // Perfil/Dispositivos para mensajería push (strict auth)
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;

      allow create, update: if signedIn() && request.auth.uid == userId &&
        request.resource.data.keys().hasOnly(['displayName', 'updatedAt']) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() > 0 &&
        request.resource.data.displayName.size() <= 120;

      allow delete: if false;

      match /devices/{token} {
        allow read: if signedIn() && request.auth.uid == userId;

        allow create, update: if signedIn() && request.auth.uid == userId &&
          request.resource.data.keys().hasOnly(['token', 'platform', 'updatedAt']) &&
          request.resource.data.token is string &&
          request.resource.data.token.size() > 0 &&
          request.resource.data.token.size() <= 500 &&
          request.resource.data.token == token &&
          request.resource.data.platform is string &&
          request.resource.data.platform.size() > 0 &&
          request.resource.data.platform.size() <= 20;

        allow delete: if false;
      }
    }
  }
}
